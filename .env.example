# Copy this file to .env and fill in real values. .env is gitignored.

# --- Database ---
# Async SQLAlchemy URL, used by both the running app and Alembic migrations.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_support

# --- LLM provider ---
# Required to actually run classification/drafting locally or run eval/run_eval.py.
# Not needed to run the mocked test suite.
ANTHROPIC_API_KEY=sk-ant-replace-me
ANTHROPIC_MODEL=claude-sonnet-4-5
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=30

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
